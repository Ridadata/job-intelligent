# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres

# ── JWT Auth ──
JWT_SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRE_MINUTES=60

# ── Job APIs (optional — enables API ingestion) ──
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
JSEARCH_API_KEY=your-jsearch-rapidapi-key
FRANCE_TRAVAIL_CLIENT_ID=your-france-travail-client-id
FRANCE_TRAVAIL_CLIENT_SECRET=your-france-travail-client-secret

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Sentence-BERT ──
SBERT_MODEL=all-MiniLM-L6-v2

# ── spaCy ──
SPACY_MODEL=fr_core_news_md

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Airflow ──
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=replace-with-a-real-fernet-key-use-python-cryptography
AIRFLOW__CORE__LOAD_EXAMPLES=false
